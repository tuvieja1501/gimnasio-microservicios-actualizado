{
  "info": {
    "name": "Gimnasio Microservicios",
    "description": "Coleccion de pruebas para los 10 microservicios del Sistema de Gestion de Gimnasio. Importa esta coleccion en Postman y ejecuta los requests en orden para probar los flujos completos incluyendo comunicacion Feign.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "url_socios",       "value": "http://localhost:8081" },
    { "key": "url_membresias",   "value": "http://localhost:8082" },
    { "key": "url_instructores", "value": "http://localhost:8083" },
    { "key": "url_clases",       "value": "http://localhost:8084" },
    { "key": "url_reservas",     "value": "http://localhost:8085" },
    { "key": "url_pagos",        "value": "http://localhost:8086" },
    { "key": "url_equipos",      "value": "http://localhost:8087" },
    { "key": "url_rutinas",      "value": "http://localhost:8088" },
    { "key": "url_asistencias",  "value": "http://localhost:8089" },
    { "key": "url_sucursales",   "value": "http://localhost:8090" }
  ],
  "item": [
    {
      "name": "01 - ms-socios",
      "item": [
        {
          "name": "Listar socios",
          "request": { "method": "GET", "url": "{{url_socios}}/api/socios" }
        },
        {
          "name": "Obtener socio por id",
          "request": { "method": "GET", "url": "{{url_socios}}/api/socios/1" }
        },
        {
          "name": "Crear socio",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{url_socios}}/api/socios",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Martin\",\n  \"apellido\": \"Lopez\",\n  \"rut\": \"20111222-3\",\n  \"email\": \"martin.lopez@mail.cl\",\n  \"telefono\": \"+56911223344\",\n  \"fechaNacimiento\": \"1999-05-10\",\n  \"estado\": \"ACTIVO\"\n}"
            }
          }
        },
        {
          "name": "Actualizar socio",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{url_socios}}/api/socios/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Camila\",\n  \"apellido\": \"Rojas\",\n  \"rut\": \"18234567-2\",\n  \"email\": \"camila.rojas@mail.cl\",\n  \"telefono\": \"+56912345678\",\n  \"fechaNacimiento\": \"1998-03-15\",\n  \"estado\": \"ACTIVO\"\n}"
            }
          }
        },
        {
          "name": "Cambiar estado socio",
          "request": { "method": "PATCH", "url": "{{url_socios}}/api/socios/1/estado?estado=MOROSO" }
        },
        {
          "name": "Eliminar socio",
          "request": { "method": "DELETE", "url": "{{url_socios}}/api/socios/99" }
        }
      ]
    },
